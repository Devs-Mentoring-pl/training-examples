# Auth0 – Application (Regular Web App)
AUTH0_DOMAIN=twoj-tenant.eu.auth0.com
AUTH0_CLIENT_ID=abc123xyz
AUTH0_CLIENT_SECRET=super_tajny_sekret
AUTH0_AUDIENCE=https://api.moja-aplikacja.com
AUTH0_CALLBACK_URL=http://localhost:8000/auth/callback
APP_FRONTEND_URL=http://localhost:3000
SECRET_KEY=zmien-to-na-losowy-string

# Auth0 – Machine-to-Machine (opcjonalne, dla M2M endpointu)
AUTH0_M2M_CLIENT_ID=m2m-client-id
AUTH0_M2M_CLIENT_SECRET=m2m-client-secret
AUTH0_M2M_AUDIENCE=https://api.docelowy-serwis.com
